{
  "name": "@epfl-sti/epfl-elements-rf",
  "homepage": "https://gitlab.epfl.ch/sti-nodejs/epfl-elements-react",
  "version": "4.1.2",
  "type": "module",
  "description": "React Storybook UI Components library based on the EPFL Elements specification that you can install and use on your own React projects.",
  "files": [
    "dist",
    "README.md",
    "LICENSE.md"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "scripts": {
    "build": "tsup src/index.ts",
    "lint": "eslint src --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "lint:fix": "eslint src --ext ts,tsx --report-unused-disable-directives --max-warnings 0 --fix",
    "prepare": "npm run build",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "tsup": {
    "entry": [
      "src/index.ts"
    ],
    "dts": true,
    "legacyOutput": true,
    "splitting": false,
    "format": [
      "cjs",
      "esm"
    ],
    "external": [
      "react"
    ],
    "injectStyle": true
  },
  "dependencies": {
    "@epfl-sti/epfl-elements-styles": "^5.0.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.1",
    "sort-objects-array": "^3.0.6",
    "universal-cookie": "^7.2.2"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^4.1.1",
    "@storybook/addon-links": "^9.1.5",
    "@storybook/react-vite": "^9.1.5",
    "@types/js-cookie": "^3.0.3",
    "@types/react": "^18.3.24",
    "@types/react-dom": "^18.3.7",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "@vitejs/plugin-react": "^5.0.2",
    "eslint": "^8.57.1",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "eslint-plugin-storybook": "^9.1.5",
    "react-bootstrap-icons": "^1.11.4",
    "storybook": "^9.1.5",
    "tsup": "^8.5.0",
    "typescript": "^5.0.2",
    "vite": "^7.1.5",
    "@storybook/addon-docs": "^9.1.5"
  }
}
